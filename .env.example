# Database — docker-compose dev uses trust auth on loopback (127.0.0.1:5433).
# Prod: prefer .pgpass or PGSERVICEFILE. tls_required controls TLS.
DATABASE_URL=postgres://elsereno@localhost:5433/elsereno?sslmode=disable
# PGPASSFILE=/path/to/.pgpass   # 0600
# PGSERVICEFILE=/path/to/pg_service.conf

# Vault — prefer interactive prompt. Env vars with secrets leak via
# /proc/<pid>/environ and `ps e`; a warning is emitted when a TTY is
# present and this variable is set (ADR-026, PITF-032).
ELSERENO_VAULT_PASSPHRASE=

# External APIs — prefer `elsereno creds store`. Env acceptable for CI/cron
# with documented rationale; same PITF-032 applies.
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=

OTEL_EXPORTER_OTLP_ENDPOINT=
ELSERENO_CONFIG=
ELSERENO_WEB_BIND=127.0.0.1:8787
ELSERENO_WEB_TOKEN_TTL_DAYS=30
ELSERENO_LOG_LEVEL=info
